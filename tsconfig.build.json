{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* Emit into dist/ — disable noEmit, add declaration files, set rootDir. */
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    /* Build only — exclude vitest globals (not needed at emit time). */
    "types": ["node"]
  },
  "include": ["src"]
}

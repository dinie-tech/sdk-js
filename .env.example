# Dinie SDK — smoke E2E credentials (deferred, non-gate — see architecture §11).
#
# Copy this file to `.env` (gitignored) to run `npm run smoke` once the live
# `sdk-smoke-test` credentials exist. The runtime test suite does NOT need these
# — it mocks undici and makes no network calls.

DINIE_CLIENT_ID=
DINIE_CLIENT_SECRET=
DINIE_BASE_URL=
DINIE_WEBHOOK_SECRET=
